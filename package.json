{
  "name": "rocketchat-ts-sdk",
  "version": "1.4.12",
  "description": "A TypeScript SDK for RocketChat API",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "rocketchat",
    "api",
    "sdk",
    "typescript",
    "chat",
    "messaging"
  ],
  "author": "Rakib Miah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rakify/rocketchat-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/rakify/rocketchat-ts-sdk/issues"
  },
  "homepage": "https://github.com/rakify/rocketchat-ts-sdk#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "rollup": "^4.5.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "tslib": "^2.8.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
